delimiters "$", "$"

htmlFile(headers, rows) ::=  <<
<!DOCTYPE html>
<html>
<body>
<table border="1">
    <tr>
        $headers: {h | <th>$h$</th>}; separator="\n"$
    </tr>
    $rows: {row | $htmlRow(row)$}; separator="\n"$
</table>
</body>
</html>
>>

htmlRow(cells) ::= <<
<tr>
    $cells: {c | <td>$c$</td>}; separator="\n"$
</tr>
>>